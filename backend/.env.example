# AgentCore Runtime Filesystem Demo - Backend Configuration

# AWS Region
AWS_REGION=us-west-2

# AgentCore Runtime ARN (created by infra/setup-runtime.py)
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-west-2:111122223333:runtime/coding-agent-hybrid-storage

# EFS Access Point ARN (for /mnt/datasets)
EFS_ACCESS_POINT_ARN=arn:aws:elasticfilesystem:us-west-2:111122223333:access-point/fsap-0123456789abcdef0

# S3 Files Access Point ARN (for /mnt/tools)
S3FILES_ACCESS_POINT_ARN=arn:aws:s3files:us-west-2:111122223333:file-system/fs-0123456789abcdef0/access-point/ap-0123456789abcdef0

# Mount paths (must match runtime configuration)
SESSION_STORAGE_MOUNT=/mnt/workspace
EFS_MOUNT=/mnt/datasets
S3FILES_MOUNT=/mnt/tools

# Command execution defaults
DEFAULT_COMMAND_TIMEOUT=60
MAX_COMMAND_TIMEOUT=300
